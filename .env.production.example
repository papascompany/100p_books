# =====================================================================
# 100p_books — 운영(.env.production) 환경변수 예시
#
# Vercel 대시보드 → Project → Settings → Environment Variables 또는
#   vercel env add <KEY> production
# 으로 등록하세요. 이 파일은 깃에 체크인되며 실제 값은 절대 커밋하지 마세요.
#
# 주: vercel.ts 도입을 권장 (Vercel Knowledge Updates 2026-02-27).
#     본 저장소는 호환성을 위해 vercel.json 을 우선 작성했습니다.
# =====================================================================

# ---- Supabase (운영 프로젝트) ----
# https://supabase.com/dashboard/project/<ref>/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://<your-prod-project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<prod-anon-key>

# Server-only — NEVER expose to client bundle
SUPABASE_SERVICE_ROLE_KEY=<prod-service-role-key>

# ---- TossPayments (운영) ----
# 운영 가맹점 ID 발급 후 https://app.tosspayments.com/ 에서 라이브 키 확인
# 보안 키(server) — TOSS_SECRET_KEY 는 live_sk_... 로 시작
TOSS_SECRET_KEY=live_sk_<prod-secret>
NEXT_PUBLIC_TOSS_CLIENT_KEY=live_ck_<prod-client>

# 웹훅 secret — Toss 대시보드 > 웹훅에 동일 값 등록
# /api/payments/webhook 의 X-Webhook-Secret 헤더 검증에 사용
TOSS_WEBHOOK_SECRET=<random-32+-char-secret>

# ---- App ----
# Vercel 자동 배정된 *.vercel.app 또는 사용자 도메인. 끝에 슬래시 없이.
NEXT_PUBLIC_APP_URL=https://100pbooks.example.com

# ---- 카카오 OAuth (선택) ----
# Supabase Auth > Providers > Kakao 에서 등록.
# 환경변수는 Supabase 측에 입력하므로 본 .env.production 에는 별도 선언 불필요.
# 등록 후 LoginForm.tsx 의 카카오 버튼 주석을 해제하세요.

# ---- Vercel Cron (이메일 워커) ----
# /api/cron/process-emails 호출 인증.
# Vercel Cron 자체 호출은 x-vercel-cron 헤더로 식별되어 통과되지만,
# 외부 디버그/수동 호출을 위해 Authorization Bearer 도 함께 검증한다.
CRON_SECRET=<random-32+-char-secret>

# ---- Storige (인쇄 PDF 저장·검증 백엔드) ----
# 서버 전용 — 절대 클라 노출 금지. 안전 채널로 받은 키를 Vercel env 에만 보관.
# 미설정 시 결제 후 PDF 빌드 잡이 'failed' 로 남아 admin 재시도 대상이 된다.
STORIGE_API_URL=https://api.papascompany.co.kr/api
STORIGE_API_KEY=<storige-api-key>
# STORIGE_VALIDATE=true            # 인쇄 검증(권장) — false 로 끌 수 있음
# STORIGE_RETENTION_DAYS=90        # 배송완료 후 PDF 보존 일수
# STORIGE_RETENTION_BATCH=80       # 보존정책 cron 1회 처리 주문 수
# STORIGE_MAX_UPLOAD_MB=100        # 업로드 한도(MB). Storige 한도 상향 시 함께 올릴 것
                                   # ⚠️ 100p 사진북은 ~100MB 초과 가능 → 한도/품질 조정 필요

# ---- 이메일 발송 (Phase 12 후속, 현재 stub) ----
# 아래 중 하나라도 설정되면 워커가 실제 발송을 시도. 미설정이면 잡이 cancelled 마킹.
# RESEND_API_KEY=
# SMTP_HOST=
# SMTP_PORT=
# SMTP_USER=
# SMTP_PASS=
# EMAIL_FROM="100p Books <hello@100pbooks.example.com>"

# ---- 모니터링 / 분석 (TODO, 미설정) ----
# NEXT_PUBLIC_GA_ID=
# NEXT_PUBLIC_PLAUSIBLE_DOMAIN=
# SENTRY_DSN=
