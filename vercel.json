{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "buildCommand": "pnpm build",
  "installCommand": "pnpm install --frozen-lockfile",
  "regions": [
    "icn1"
  ],
  "functions": {
    "app/api/pdf/progress/route.ts": {
      "maxDuration": 300
    },
    "app/api/payments/confirm/route.ts": {
      "maxDuration": 300,
      "memory": 1769
    },
    "app/api/admin/orders/[id]/rebuild-pdf/route.ts": {
      "maxDuration": 300,
      "memory": 1769
    },
    "app/api/cron/process-emails/route.ts": {
      "maxDuration": 60
    },
    "app/api/cron/attendance-reset/route.ts": {
      "maxDuration": 60
    },
    "app/api/cron/storige-retention/route.ts": {
      "maxDuration": 60
    }
  },
  "crons": [
    {
      "path": "/api/cron/process-emails",
      "schedule": "0 9 * * *"
    },
    {
      "path": "/api/cron/attendance-reset",
      "schedule": "0 15 * * *"
    },
    {
      "path": "/api/cron/storige-retention",
      "schedule": "0 18 * * *"
    }
  ],
  "headers": [
    {
      "source": "/sw.js",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-cache, no-store, must-revalidate"
        },
        {
          "key": "Service-Worker-Allowed",
          "value": "/"
        }
      ]
    },
    {
      "source": "/manifest.json",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=86400"
        },
        {
          "key": "Content-Type",
          "value": "application/manifest+json"
        }
      ]
    },
    {
      "source": "/api/pdf/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-store"
        }
      ]
    },
    {
      "source": "/api/admin/orders/export",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-store"
        }
      ]
    },
    {
      "source": "/api/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        }
      ]
    },
    {
      "source": "/((?!api/).*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "SAMEORIGIN"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        },
        {
          "key": "Permissions-Policy",
          "value": "camera=(self), geolocation=(), microphone=(), payment=(self), accelerometer=(), gyroscope=(), magnetometer=(), usb=(), interest-cohort=()"
        },
        {
          "key": "Content-Security-Policy",
          "value": "default-src 'self'; base-uri 'self'; object-src 'none'; frame-ancestors 'self'; form-action 'self' https://kauth.kakao.com https://api.tosspayments.com; img-src 'self' https://*.supabase.co https://images.unsplash.com https://k.kakaocdn.net data: blob:; media-src 'self' blob: data:; script-src 'self' 'unsafe-inline' https://js.tosspayments.com https://t1.daumcdn.net; style-src 'self' 'unsafe-inline'; font-src 'self' data:; worker-src 'self' blob:; connect-src 'self' https://*.supabase.co https://api.tosspayments.com https://kauth.kakao.com https://kapi.kakao.com https://images.unsplash.com; frame-src 'self' https://js.tosspayments.com https://*.tosspayments.com https://kauth.kakao.com; manifest-src 'self'"
        }
      ]
    }
  ]
}
