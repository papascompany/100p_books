# ---- Supabase ----
# Public (safe to expose to client)
NEXT_PUBLIC_SUPABASE_URL=https://XXX.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=XXX

# Server-only — NEVER expose to client bundle
SUPABASE_SERVICE_ROLE_KEY=XXX

# ---- TossPayments ----
# Server secret key — never expose. Used by /api/payments/confirm + /api/payments/webhook.
TOSS_SECRET_KEY=test_sk_XXX

# Client key — exposed to the browser via NEXT_PUBLIC_*. Used by @tosspayments/payment-sdk.
NEXT_PUBLIC_TOSS_CLIENT_KEY=test_ck_XXX

# (Optional) Webhook secret — header `X-Webhook-Secret` must match. Leave blank to disable.
TOSS_WEBHOOK_SECRET=

# ---- App ----
NEXT_PUBLIC_APP_URL=http://localhost:3000
